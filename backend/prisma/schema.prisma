generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id          String   @id @default(cuid())
  name        String
  phone       String?
  status      String   @default("disconnected") // connected, disconnected, connecting
  qrCode      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contacts    Contact[]
  messages    Message[]
  autoReplies AutoReply[]
}

model Contact {
  id          String   @id @default(cuid())
  sessionId   String
  jid         String   // WhatsApp JID (phone@s.whatsapp.net)
  name        String?
  pushName    String?
  phone       String
  avatar      String?
  labels      String?  // comma-separated labels
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  messages    Message[]

  @@unique([sessionId, jid])
}

model Message {
  id          String   @id @default(cuid())
  sessionId   String
  contactId   String?
  jid         String   // recipient/sender JID
  content     String
  type        String   @default("text") // text, image, document, audio, video
  mediaUrl    String?
  fromMe      Boolean  @default(false)
  status      String   @default("pending") // pending, sent, delivered, read, failed
  timestamp   DateTime @default(now())
  messageId   String?  // WhatsApp message ID
  createdAt   DateTime @default(now())

  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([sessionId, jid])
  @@index([timestamp])
}

model AutoReply {
  id          String   @id @default(cuid())
  sessionId   String
  trigger     String   // keyword or pattern
  response    String   // reply message
  isActive    Boolean  @default(true)
  matchType   String   @default("contains") // exact, contains, startsWith
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Broadcast {
  id          String   @id @default(cuid())
  sessionId   String
  name        String
  message     String
  recipients  String   // JSON array of JIDs
  status      String   @default("pending") // pending, sending, completed, failed
  sentCount   Int      @default(0)
  failCount   Int      @default(0)
  totalCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
