generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== AUTH ====================

model ApiKey {
  id            String   @id @default(cuid())
  name          String
  key           String   @unique
  permissions   String   @default("*")
  cidrWhitelist String?
  rateLimit     Int      @default(100)
  isActive      Boolean  @default(true)
  lastUsedAt    DateTime?
  expiresAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  auditLogs     AuditLog[]
}

// ==================== SESSIONS (MULTI-PLATFORM) ====================

model Session {
  id              String   @id @default(cuid())
  name            String
  platform        String   @default("whatsapp") // whatsapp, whatsapp_api, telegram, instagram, messenger
  connectionType  String   @default("qr") // qr, pairing_code, api_token, phone_otp, login
  status          String   @default("disconnected") // disconnected, connecting, qr_ready, otp_required, connected
  phone           String?
  username        String?
  avatar          String?

  // Connection credentials (JSON - platform-specific)
  credentials     String?  // Encrypted JSON with platform creds

  // WhatsApp API specific (legacy compat)
  phoneNumberId   String?
  accessToken     String?
  waBusinessId    String?

  // QR/Auth state
  qrCode          String?  // Current QR code data (base64 or text)
  pairingCode     String?  // Current pairing code

  // Session storage path (for Baileys auth state, GramJS session, etc)
  sessionPath     String?

  webhookVerifyToken String?
  webhookUrl      String?
  metadata        String?  // JSON
  lastSeen        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  contacts        Contact[]
  messages        Message[]
  groups          Group[]
  labels          Label[]
  autoReplies     AutoReply[]
  broadcasts      Broadcast[]
}

// ==================== CONTACTS ====================

model Contact {
  id          String   @id @default(cuid())
  sessionId   String
  platformId  String   // Platform-specific ID (jid, chat_id, ig_user_id, psid)
  name        String?
  pushName    String?
  phone       String?
  username    String?
  avatar      String?
  isGroup     Boolean  @default(false)
  isBlocked   Boolean  @default(false)
  lastMessage String?  // Preview of last message
  lastMsgTime DateTime?
  unreadCount Int      @default(0)
  metadata    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  messages    Message[]

  @@unique([sessionId, platformId])
  @@index([phone])
  @@index([username])
  @@index([lastMsgTime])
}

// ==================== MESSAGES ====================

model Message {
  id            String   @id @default(cuid())
  sessionId     String
  contactId     String?
  platformChatId String  // Platform-specific chat/conversation ID
  senderName    String?
  content       String
  type          String   @default("text") // text, image, video, document, audio, sticker, voice, location, contact, template, reaction
  mediaUrl      String?
  mediaMimeType String?
  mediaFileName String?
  mediaSize     Int?
  thumbnailUrl  String?
  fromMe        Boolean  @default(false)
  status        String   @default("pending") // pending, sent, delivered, read, failed, received
  timestamp     DateTime @default(now())
  externalMsgId String?  // Platform message ID
  quotedMsgId   String?  // Reply-to message ID
  quotedContent String?  // Preview of quoted message
  isForwarded   Boolean  @default(false)
  isStarred     Boolean  @default(false)
  metadata      String?  // JSON (buttons, reactions, etc)
  createdAt     DateTime @default(now())

  session       Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  contact       Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([sessionId, platformChatId])
  @@index([timestamp])
  @@index([externalMsgId])
  @@index([sessionId, timestamp])
}

// ==================== GROUPS ====================

model Group {
  id            String   @id @default(cuid())
  sessionId     String
  platformId    String
  name          String
  description   String?
  participants  String   // JSON array
  admins        String?  // JSON array
  owner         String?
  profilePic    String?
  memberCount   Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  session       Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, platformId])
}

// ==================== LABELS ====================

model Label {
  id          String   @id @default(cuid())
  sessionId   String
  name        String
  color       String   @default("#25D366")
  chatIds     String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// ==================== AUTO REPLIES ====================

model AutoReply {
  id          String   @id @default(cuid())
  sessionId   String
  trigger     String
  response    String
  isActive    Boolean  @default(true)
  matchType   String   @default("contains") // exact, contains, startsWith, regex
  platforms   String   @default("*") // JSON array of platforms or "*" for all
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// ==================== BROADCASTS ====================

model Broadcast {
  id          String   @id @default(cuid())
  sessionId   String
  name        String
  message     String
  mediaUrl    String?
  recipients  String   // JSON array
  status      String   @default("pending")
  sentCount   Int      @default(0)
  failCount   Int      @default(0)
  totalCount  Int      @default(0)
  delay       Int      @default(2000)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// ==================== WEBHOOKS ====================

model Webhook {
  id          String   @id @default(cuid())
  url         String
  events      String   @default("*")
  secret      String?
  isActive    Boolean  @default(true)
  retries     Int      @default(3)
  lastStatus  Int?
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== AUDIT LOG ====================

model AuditLog {
  id          String   @id @default(cuid())
  apiKeyId    String?
  action      String
  resource    String?
  details     String?
  ip          String?
  userAgent   String?
  statusCode  Int?
  createdAt   DateTime @default(now())

  apiKey      ApiKey?  @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([action])
}
