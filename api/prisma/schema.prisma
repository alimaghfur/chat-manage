generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== AUTH ====================

model ApiKey {
  id          String   @id @default(cuid())
  name        String
  key         String   @unique
  permissions String   @default("*") // JSON array of permissions or "*" for all
  cidrWhitelist String? // JSON array of allowed CIDRs, null = allow all
  rateLimit   Int      @default(100) // requests per minute
  isActive    Boolean  @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  auditLogs   AuditLog[]
}

// ==================== SESSIONS (MULTI-PLATFORM) ====================

model Session {
  id          String   @id @default(cuid())
  name        String
  platform    String   @default("whatsapp") // whatsapp, telegram, instagram, messenger
  phone       String?
  status      String   @default("disconnected") // connected, disconnected, connecting

  // === Platform Credentials (stored as JSON for flexibility) ===
  // WhatsApp: { phoneNumberId, accessToken, waBusinessId }
  // Telegram: { botToken, botUsername }
  // Instagram: { accessToken, igUserId, pageId }
  // Messenger: { pageAccessToken, pageId, appSecret }
  credentials String?  // JSON - platform-specific credentials

  // Legacy WhatsApp fields (kept for backward compat, will be read from credentials)
  phoneNumberId String?  // WhatsApp Business Phone Number ID
  accessToken   String?  // Meta API access token / Telegram bot token
  waBusinessId  String?  // WhatsApp Business Account ID

  webhookVerifyToken String? // Token for webhook verification
  proxyUrl    String?  // per-session proxy
  webhookUrl  String?  // per-session webhook override
  metadata    String?  // JSON extra data
  avatar      String?  // Platform avatar/profile picture URL
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contacts    Contact[]
  messages    Message[]
  groups      Group[]
  labels      Label[]
  autoReplies AutoReply[]
  broadcasts  Broadcast[]
}

// ==================== CONTACTS ====================

model Contact {
  id          String   @id @default(cuid())
  sessionId   String
  platformId  String   // Platform-specific identifier (jid, chat_id, ig_user_id, psid)
  name        String?
  pushName    String?
  phone       String?
  username    String?  // Telegram username, Instagram handle
  avatar      String?
  isGroup     Boolean  @default(false)
  metadata    String?  // JSON
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  messages    Message[]

  @@unique([sessionId, platformId])
  @@index([phone])
  @@index([username])
}

// ==================== MESSAGES ====================

model Message {
  id            String   @id @default(cuid())
  sessionId     String
  contactId     String?
  platformId    String   // Platform-specific chat/conversation ID
  content       String
  type          String   @default("text") // text, image, video, document, audio, sticker, reaction, location, contact, template
  mediaUrl      String?
  mimeType      String?
  fileName      String?
  fromMe        Boolean  @default(false)
  status        String   @default("pending") // pending, sent, delivered, read, failed, received
  timestamp     DateTime @default(now())
  externalMsgId String?  // Platform message ID (wa msg id, telegram msg id, etc)
  quotedMsgId   String?  // reply to message
  metadata      String?  // JSON (reactions, buttons, etc)
  createdAt     DateTime @default(now())

  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([sessionId, platformId])
  @@index([timestamp])
  @@index([externalMsgId])
}

// ==================== GROUPS ====================

model Group {
  id            String   @id @default(cuid())
  sessionId     String
  platformId    String   // Platform-specific group ID
  name          String
  description   String?
  participants  String   // JSON array
  admins        String?  // JSON array
  owner         String?
  profilePic    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  session       Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, platformId])
}

// ==================== LABELS ====================

model Label {
  id          String   @id @default(cuid())
  sessionId   String
  name        String
  color       String   @default("#25D366")
  chatIds     String   @default("[]") // JSON array of platform IDs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// ==================== AUTO REPLIES ====================

model AutoReply {
  id          String   @id @default(cuid())
  sessionId   String
  trigger     String
  response    String
  isActive    Boolean  @default(true)
  matchType   String   @default("contains") // exact, contains, startsWith, regex
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// ==================== BROADCASTS ====================

model Broadcast {
  id          String   @id @default(cuid())
  sessionId   String
  name        String
  message     String
  mediaUrl    String?
  recipients  String   // JSON array of platform IDs
  status      String   @default("pending") // pending, sending, completed, failed
  sentCount   Int      @default(0)
  failCount   Int      @default(0)
  totalCount  Int      @default(0)
  delay       Int      @default(2000) // delay between messages in ms
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// ==================== WEBHOOKS ====================

model Webhook {
  id          String   @id @default(cuid())
  url         String
  events      String   @default("*") // JSON array: ["message", "status", "connection"] or "*"
  secret      String?  // HMAC secret for signature
  isActive    Boolean  @default(true)
  retries     Int      @default(3)
  lastStatus  Int?     // last HTTP status code
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== AUDIT LOG ====================

model AuditLog {
  id          String   @id @default(cuid())
  apiKeyId    String?
  action      String   // e.g. "session.create", "message.send"
  resource    String?  // e.g. "session:abc123"
  details     String?  // JSON
  ip          String?
  userAgent   String?
  statusCode  Int?
  createdAt   DateTime @default(now())

  apiKey      ApiKey?  @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([action])
}
