# ========================================
# MULTI-PLATFORM CHAT MANAGER
# ========================================

# Database
DATABASE_URL="file:./dev.db"

# Server
PORT=3001
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Authentication
API_MASTER_KEY=your-master-key-here

# ========================================
# PLATFORM: WhatsApp Cloud API (Optional)
# ========================================
WA_CLOUD_API_URL=https://graph.facebook.com/v21.0
WA_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# ========================================
# PLATFORM: Telegram
# Get from https://my.telegram.org
# ========================================
TELEGRAM_API_ID=your-api-id
TELEGRAM_API_HASH=your-api-hash

# ========================================
# PLATFORM: Instagram
# No special env vars needed (uses username/password login)
# ========================================

# ========================================
# PLATFORM: Messenger
# No special env vars needed (uses email/password or appState cookies)
# Optional: For webhook verification if using official API
# ========================================
FB_WEBHOOK_VERIFY_TOKEN=your-fb-webhook-token
